# =============================================================================
# FinScope AI — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=FinScope AI
APP_ENV=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# JWT Auth
# ---------------------------------------------------------------------------
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=finscope
POSTGRES_USER=finscope_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password
# Constructed automatically by pydantic-settings:
# DATABASE_URL=postgresql+asyncpg://finscope_user:password@postgres:5432/finscope

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=                # leave blank for local dev, set for prod
# REDIS_URL=redis://:password@redis:6379/0

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC

# ---------------------------------------------------------------------------
# MLflow
# ---------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=finscope-experiments
# Optional: S3 artifact store for prod
# MLFLOW_ARTIFACT_ROOT=s3://your-bucket/mlflow

# ---------------------------------------------------------------------------
# CORS (comma-separated origins)
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------------------
# Email (SendGrid)
# ---------------------------------------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@finscope.ai

# ---------------------------------------------------------------------------
# SMS (Twilio) — optional
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---------------------------------------------------------------------------
# LLM / Embeddings (Phase 9 — RAG chatbot)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# FX Rates API (Phase 8 — multi-currency)
# ---------------------------------------------------------------------------
FX_API_KEY=
FX_BASE_CURRENCY=USD

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# ---------------------------------------------------------------------------
# File Storage
# ---------------------------------------------------------------------------
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_SIZE_MB=10
